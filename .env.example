# TabTab environment configuration template.
# Copy to `.env` for local development. `.env` is gitignored.

# --- Builder build ---
# Optional override for Skia install location.
# SKIA_DIR=/path/to/skia

# --- Live data engine (design-time only) ---
# Example REST endpoint for the customer-manager example.
# EXAMPLE_API_BASE=https://api.example.com

# Example PostgreSQL DSN (used by the customer-manager example).
# EXAMPLE_PG_DSN=postgres://user:pass@localhost:5432/customers

# --- Quick-run preview ---
# Path to the JDK used to compile/run generated projects.
# JAVA_HOME=/path/to/jdk-21

# --- GitHub ---
# GITHUB_TOKEN is only needed if `gh` is not authenticated.
# GITHUB_TOKEN=
